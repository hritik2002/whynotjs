{
  "name": "whynotjs",
  "version": "0.1.0",
  "description": "Track why, when, and where your JavaScript objects changed — like Git blame for plain objects.",
  "license": "MIT",
  "author": "Hritik Sharma <sharmahritik2002@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hritik2002/whynotjs.git"
  },
  "homepage": "https://github.com/hritik2002/whynotjs#readme",
  "bugs": {
    "url": "https://github.com/hritik2002/whynotjs/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "proxy",
    "debug",
    "devtools",
    "mutation",
    "tracking",
    "audit",
    "stack-trace",
    "javascript",
    "typescript",
    "debugging",
    "state"
  ],
  "engines": {
    "node": ">=14"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
